# ══════════════════════════════════════════════════════════════
#  ARIA Voice Agent — Environment Variables
#  Copy this file to voice-agent/.env and fill in real values.
#  agent.py reads this file automatically on startup.
# ══════════════════════════════════════════════════════════════

# ── LiveKit  (livekit.io — free Sandbox tier available) ───────
# Create a project at https://cloud.livekit.io/
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deepgram STT  (https://console.deepgram.com) ──────────────
# Free tier: $200 credit on signup
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cerebras LLM  (https://cloud.cerebras.ai) ─────────────────
# Free tier available — faster than OpenAI for inference
CEREBRAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cartesia TTS  (https://play.cartesia.ai) ──────────────────
# Free tier available
CARTESIA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App URL (your Render deployment) ──────────────────────────
NEXT_PUBLIC_APP_URL=https://bec-vortex-os.onrender.com
